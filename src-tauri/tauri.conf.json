{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "萌宠小欣子",
  "version": "0.1.0",
  "identifier": "com.yanghaoraneve.pet-xiaoxinzi",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "萌宠小欣子",
        "width": 400,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "高清透明人物桌宠",
    "longDescription": "萌宠小欣子高清透明人物桌宠，支持基础动作、拖拽和自动桌面移动。",
    "category": "Utility",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
